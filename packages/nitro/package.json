{
  "name": "@uloki/nitro",
  "version": "0.0.1",
  "type": "module",
  "description": "Nitro server plugin for Loki logging — hooks, runtime, config",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "uloki": "workspace:*"
  },
  "devDependencies": {
    "nitro": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "nitro": ">=3.0"
  }
}
