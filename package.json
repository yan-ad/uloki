{
  "name": "nitro-loki",
  "version": "0.0.1",
  "private": true,
  "description": "Loki logging transport for Nitro — the server engine that powers Nuxt",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "play:nuxt": "pnpm -C playground/nuxt dev",
    "play:nitro": "pnpm -C playground/nitro dev",
    "release": "bumpp && pnpm -r publish"
  },
  "devDependencies": {
    "bumpp": "^10.0.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20"
  }
}
